{
  "name": "emperor-workbench-frontend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "^18.18.0 || ^19.8.0 || >=20.0.0"
  },
  "scripts": {
    "dev": "next dev -p ${PORT:-9000}",
    "build": "next build",
    "performance:budget": "node scripts/check-performance-budgets.mjs",
    "performance:cluster3d": "vite-node --config vitest.config.ts scripts/benchmark-cluster-3d.ts",
    "performance:history": "vite-node --config vitest.config.ts scripts/benchmark-historical-grouping.ts",
    "performance:locations": "vite-node --config vitest.config.ts scripts/benchmark-graph-locations.ts",
    "performance:grouping": "vite-node --config vitest.config.ts scripts/benchmark-log-grouping.ts",
    "performance:logs": "vite-node --config vitest.config.ts scripts/benchmark-log-scalar-plan.ts",
    "start": "next start -p ${PORT:-9000}",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "VITE_CJS_IGNORE_WARNING=true vitest run"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tanstack/react-query": "^5.90.0",
    "@xyflow/react": "^12.9.0",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.6",
    "lucide-react": "^0.468.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@testing-library/jest-dom": "^6.9.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.0",
    "@types/dagre": "^0.7.53",
    "@types/node": "^22.18.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.18",
    "jsdom": "^25.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.0",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "form-data": "4.0.6",
    "postcss": "8.5.15",
    "vite": "6.4.3"
  }
}
