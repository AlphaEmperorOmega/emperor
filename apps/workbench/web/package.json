{
  "name": "emperor-workbench-frontend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "node scripts/start-next.mjs dev",
    "build": "next build",
    "performance:budget": "node scripts/check-performance-budgets.mjs",
    "performance:browser": "node scripts/benchmark-browser-long-session.mjs",
    "performance:cluster3d": "vite-node --config vitest.config.ts scripts/benchmark-cluster-3d.ts",
    "performance:history": "vite-node --config vitest.config.ts scripts/benchmark-historical-grouping.ts",
    "performance:locations": "vite-node --config vitest.config.ts scripts/benchmark-graph-locations.ts",
    "performance:grouping": "vite-node --config vitest.config.ts scripts/benchmark-log-grouping.ts",
    "performance:logs": "vite-node --config vitest.config.ts scripts/benchmark-log-scalar-plan.ts",
    "start": "node scripts/start-next.mjs start",
    "lint": "eslint . --max-warnings 0",
    "test:contract:e2e": "cross-env WORKBENCH_RUN_CONTRACT_E2E=1 VITE_CJS_IGNORE_WARNING=true vitest run tests/backend-frontend-contract.e2e.test.tsx",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "cross-env VITE_CJS_IGNORE_WARNING=true vitest run"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tanstack/react-query": "^5.90.0",
    "@xyflow/react": "^12.9.0",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.6",
    "lucide-react": "^0.468.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.0",
    "@types/dagre": "^0.7.53",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "axe-core": "^4.12.1",
    "babel-plugin-react-compiler": "1.0.0",
    "cross-env": "7.0.3",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "jsdom": "^25.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.0",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "form-data": "4.0.6",
    "postcss": "8.5.15",
    "vite": "6.4.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3"
  }
}
